---
const progress = [
  { name: "Python", current: 44, total: 82, percent: 53.6 },
  { name: "Frontend", current: 74, total: 120, percent: 61.6 },
  { name: "Cyber Security", current: 1, total: 301, percent: 0.3 },
  { name: "Backend", current: 75, total: 155, percent: 48.3 }
];
---

<section class="py-24 bg-transparent relative overflow-hidden">
  <div class="container mx-auto px-4">
    <div class="reveal max-w-2xl mx-auto p-8 bg-white/5 backdrop-blur-xl rounded-3xl border border-white/10 shadow-2xl relative group hover:border-primary-cyan/20 transition-all duration-500">
      
      <!-- Glow Effect -->
      <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary-cyan/10 rounded-full blur-[80px] group-hover:bg-primary-cyan/20 transition-all duration-700"></div>
      
      <!-- Header -->
      <div class="flex items-center justify-between mb-10 relative">
        <div>
          <h2 class="text-3xl font-bold text-white mb-1 tracking-tight">Oswaldo Bello</h2>
          <p class="text-gray-400 text-sm">
            Explora mi progreso en 
            <a href="https://roadmap.sh/u/bellooswaldo" target="_blank" class="text-primary-cyan font-semibold hover:text-white transition-colors duration-300">
              roadmap.sh/u/bellooswaldo
            </a>
          </p>
        </div>
        <div class="w-14 h-14 bg-primary-cyan/10 rounded-2xl flex items-center justify-center border border-primary-cyan/20 group-hover:border-primary-cyan/50 transition-all duration-500 shadow-lg shadow-primary-cyan/5">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-cyan"><path d="M12 13V2l8 4-8 4Z"/><path d="m20.5 10.3 1.9 4.3c.1.2.1.5 0 .7l-2.1 4.6c-.2.5-.8.8-1.3.8H5c-.5 0-1.1-.3-1.3-.8l-2.1-4.6c-.1-.2-.1-.5 0-.7l1.9-4.3"/><path d="M15 22v-5H9v5"/></svg>
        </div>
      </div>

      <!-- Roadmap Progress Bars -->
      <div class="space-y-8 relative">
        {progress.map((item) => (
          <div class="space-y-3">
            <div class="flex justify-between items-center text-sm">
              <span class="font-medium text-gray-200 tracking-wide uppercase text-xs">{item.name}</span>
              <span class="text-gray-400 font-mono">{item.current} / {item.total}</span>
            </div>
            <div class="h-2 w-full bg-white/5 rounded-full overflow-hidden border border-white/5 shadow-inner">
              <div 
                class="h-full bg-gradient-to-r from-primary-cyan to-primary-blue rounded-full relative transition-all duration-1000 ease-out shadow-[0_0_10px_rgba(0,217,255,0.4)]"
                style={`width: ${item.percent}%`}
              >
                <!-- Dot indicator -->
                <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1 h-1 bg-white rounded-full blur-[1px]"></div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Footer Summary -->
      <div class="mt-12 pt-8 border-t border-white/10 grid grid-cols-2 gap-6 relative">
        <div class="flex items-center gap-3">
          <div class="w-6 h-6 bg-green-500/20 rounded-full flex items-center justify-center border border-green-500/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <span class="block text-xl font-bold text-white">330</span>
            <span class="text-[10px] text-gray-500 uppercase tracking-widest font-semibold">Temas completados</span>
          </div>
        </div>
        
        <div class="flex items-center gap-3">
          <div class="w-6 h-6 bg-primary-cyan/20 rounded-full flex items-center justify-center border border-primary-cyan/30">
             <div class="w-2 h-2 bg-primary-cyan rounded-full animate-ping"></div>
          </div>
          <div>
            <span class="block text-xl font-bold text-white">38</span>
            <span class="text-[10px] text-gray-500 uppercase tracking-widest font-semibold">Aprendiendo ahora</span>
          </div>
        </div>
      </div>

      <!-- Action Button -->
      <div class="mt-10 relative">
        <a 
          href="https://roadmap.sh/u/bellooswaldo" 
          target="_blank" 
          class="flex items-center justify-center gap-2 w-full py-4 bg-gradient-to-r from-primary-cyan/10 to-primary-blue/10 hover:from-primary-cyan/20 hover:to-primary-blue/20 border border-primary-cyan/20 rounded-xl text-primary-cyan font-bold transition-all duration-300 group/btn overflow-hidden relative"
        >
          <span class="relative z-10">Ver perfil completo en Roadmap.sh</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="relative z-10 group-hover/btn:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          <div class="absolute inset-0 bg-gradient-to-r from-primary-cyan/0 via-white/5 to-primary-blue/0 translate-x-[-100%] group-hover/btn:translate-x-[100%] transition-transform duration-1000"></div>
        </a>
      </div>
    </div>
  </div>
</section>
